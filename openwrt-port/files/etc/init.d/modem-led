#!/bin/sh /etc/rc.common
# procd wrapper for the modem-status LED engine (/usr/sbin/modem-led).
# The daemon runs as the standalone engine, NOT as an rc.common re-entry, so it
# never holds the procd service lock -- otherwise stop/reboot deadlock on it.
#
# LEDs driven by connection state; only LEDs on the "none" kernel trigger are
# touched, so a LuCI override (e.g. default-on) wins. Disable the whole feature
# with `/etc/init.d/modem-led disable` or uci modem_led.globals.enabled=0.

USE_PROCD=1
START=96
STOP=10

ENGINE=/usr/sbin/modem-led
# NB: `status` is a built-in rc.common command (prints running/stopped), so the
# LED detail command is named `ledstate` to avoid being shadowed.
EXTRA_COMMANDS="simulate ledstate"
EXTRA_HELP="	simulate <state>   force LEDs: 5g-up|5g-att|4g-up|4g-att|off
	ledstate           show detected modem state and per-LED trigger/brightness"

start_service() {
	local enabled port interval
	config_load modem_led
	config_get_bool enabled globals enabled 1
	config_get port     globals port     /dev/ttyUSB2
	config_get interval globals interval  10
	[ "$enabled" = 1 ] || return 0

	procd_open_instance
	procd_set_param command "$ENGINE" daemon "$port" "$interval"
	procd_set_param respawn
	procd_close_instance
}

stop_service() {
	"$ENGINE" off
}

simulate() {
	"$ENGINE" simulate "$@"
}

ledstate() {
	local port
	config_load modem_led
	config_get port globals port /dev/ttyUSB2
	"$ENGINE" status "$port"
}
