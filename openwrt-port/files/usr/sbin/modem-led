#!/bin/sh
# Modem-status LED engine for the Vistotek C6130G-5G (Quectel RM520N-GL).
# Invoked by /etc/init.d/modem-led. Runs as a plain standalone process (NOT via
# rc.common) so the long-running daemon never holds the procd service lock --
# see the git/design notes: running the loop as `/etc/init.d/modem-led loop`
# deadlocks every later stop/reboot on /tmp/lock/procd_<svc>.lock.
#
# Semantics (exactly one LED lit at a time):
#   5G (SA/NSA) + data session up -> blue:5g
#   5G, no data session           -> yellow:5g
#   LTE + data session up         -> blue:4g
#   LTE, no data session          -> yellow:4g
#   no service / searching / off  -> all four off
#
# Only LEDs left on the "none" kernel trigger are driven; set any other trigger
# in LuCI (e.g. default-on) to take an LED out of daemon control.

LEDS="blue:5g yellow:5g blue:4g yellow:4g"
AT_PORT="${AT_PORT:-/dev/ttyUSB2}"

# --- serial AT helper -------------------------------------------------------
at_cmd() {
	local cmd="$1" dev="$AT_PORT" line
	[ -c "$dev" ] || return 1
	exec 8<>"$dev" 2>/dev/null || return 1
	printf '%s\r' "$cmd" >&8
	while IFS= read -t 2 -r line <&8; do
		line=$(printf '%s' "$line" | tr -d '\r')
		printf '%s\n' "$line"
		case "$line" in
			OK|ERROR|"+CME ERROR:"*|"+CMS ERROR:"*) break ;;
		esac
	done
	exec 8>&-
	return 0
}

# --- state detection: echoes 5g-up 5g-att 4g-up 4g-att off ------------------
detect_state() {
	local qeng cgact rat
	qeng=$(at_cmd 'AT+QENG="servingcell"')
	case "$qeng" in
		*NR5G-SA*|*NR5G-NSA*) rat=5g ;;
		*LTE*|*WCDMA*|*TD-SCDMA*|*GSM*|*CDMA*|*HDR*) rat=4g ;;
		*) rat=none ;;
	esac
	[ "$rat" = none ] && { echo off; return; }
	cgact=$(at_cmd 'AT+CGACT?')
	if printf '%s' "$cgact" | grep -qE '\+CGACT: *[0-9]+, *1'; then
		echo "$rat-up"
	else
		echo "$rat-att"
	fi
}

# --- LED control (respects user override via the kernel trigger) ------------
led_active_trigger() {
	sed -n 's/.*\[\([^]]*\)\].*/\1/p' "/sys/class/leds/$1/trigger" 2>/dev/null
}

set_led() {
	local led="$1" want="$2" path="/sys/class/leds/$1" max
	[ -w "$path/brightness" ] || return 0
	[ "$(led_active_trigger "$led")" = none ] || return 0
	if [ "$want" = 1 ]; then
		max=$(cat "$path/max_brightness" 2>/dev/null)
		[ -n "$max" ] && [ "$max" -gt 0 ] 2>/dev/null || max=1
		echo "$max" > "$path/brightness"
	else
		echo 0 > "$path/brightness"
	fi
}

apply() {
	local b5=0 y5=0 b4=0 y4=0
	case "$1" in
		5g-up)  b5=1 ;;
		5g-att) y5=1 ;;
		4g-up)  b4=1 ;;
		4g-att) y4=1 ;;
		off)    ;;
		*) echo "unknown state: $1" >&2; return 1 ;;
	esac
	set_led blue:5g   "$b5"
	set_led yellow:5g "$y5"
	set_led blue:4g   "$b4"
	set_led yellow:4g "$y4"
}

# --- entry points -----------------------------------------------------------
cmd="$1"; [ $# -gt 0 ] && shift
case "$cmd" in
	daemon)
		AT_PORT="${1:-/dev/ttyUSB2}"
		interval="${2:-10}"
		# Respond to SIGTERM promptly: back the sleep with `wait` so the signal
		# interrupts it immediately (a plain `sleep` with a TERM trap is deferred
		# until the sleep finishes, delaying procd's stop by up to $interval).
		running=1
		sleep_pid=
		trap 'running=0; [ -n "$sleep_pid" ] && kill "$sleep_pid" 2>/dev/null' TERM INT
		[ -c "$AT_PORT" ] && (stty raw -echo clocal -crtscts 115200 2>/dev/null) < "$AT_PORT"
		while [ "$running" = 1 ]; do
			apply "$(detect_state)"
			[ "$running" = 1 ] || break
			sleep "$interval" &
			sleep_pid=$!
			wait "$sleep_pid"
			sleep_pid=
		done
		apply off
		;;
	simulate)
		[ -n "$1" ] || { echo "usage: modem-led simulate 5g-up|5g-att|4g-up|4g-att|off" >&2; exit 1; }
		apply "$1" && echo "applied: $1"
		;;
	status)
		AT_PORT="${1:-/dev/ttyUSB2}"
		echo "port:  $AT_PORT"
		echo "state: $(detect_state)"
		for l in $LEDS; do
			printf '  %-10s trigger=%s brightness=%s\n' "$l" \
				"$(led_active_trigger "$l")" \
				"$(cat "/sys/class/leds/$l/brightness" 2>/dev/null)"
		done
		;;
	off)
		apply off
		;;
	*)
		echo "usage: modem-led daemon <port> <interval> | simulate <state> | status [port] | off" >&2
		exit 1
		;;
esac
